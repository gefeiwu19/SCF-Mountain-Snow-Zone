# =============================================
# SCF-Mountain-Snow-Zone .gitignore
# =============================================

# === OS files ===
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# === Editor / IDE ===
*.swp
*.swo
*~
.vscode/
.idea/
*.Rproj.user
*.sublime-workspace
*.sublime-project

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/
*.so

# === Jupyter ===
.ipynb_checkpoints/

# === R ===
.Rhistory
.RData
.Rproj.user

# === Large data files (not tracked) ===
# Raw and intermediate data — too large for GitHub
*.tif
*.tiff
*.csv
*.shp
*.dbf
*.shx
*.prj
*.cpg
*.sbn
*.sbx
*.zip
*.gz
*.tar
*.7z
*.geojson
*.gpkg

# === Generated outputs ===
# Figures and results are regenerated by running the scripts
figures/*.png
figures/*.pdf
figures/*.jpg
figures/*.svg
results/
!figures/README.md

# === GEE credentials (never commit) ===
.config/earthengine/
credentials
*.json.enc
